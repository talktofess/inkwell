# ─────────────────────────────────────────────────────────────
# Inkwell environment configuration
# Copy to `.env.local` for local dev. In Vercel, set these in
# Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service-role key (SECRET — server-only, never exposed to the browser).
# Found in Supabase → Project Settings → API → service_role.
# All database access happens server-side via this key, so RLS is bypassed
# intentionally and the app is protected by the passphrase gate below.
SUPABASE_SERVICE_ROLE_KEY=

# The single passphrase that unlocks the app. Pick something long.
# Anyone who knows it can read/write your manuscripts, so treat it like a password.
APP_PASSWORD=

# A long random string used to sign the auth cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
